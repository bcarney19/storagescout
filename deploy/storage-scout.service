[Unit]
Description=Storage Scout API
After=network.target

[Service]
User=www-data
WorkingDirectory=/var/www/storagescout/backend
EnvironmentFile=/var/www/storagescout/backend/.env
ExecStart=/var/www/storagescout/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
