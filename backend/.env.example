# Get a free key at https://console.cloud.google.com — enable "Places API"
# The $200/month free credit covers ~11,700 facility lookups
GOOGLE_PLACES_API_KEY=

# Optional. When set, POST /api/import/{state} requires either:
# Authorization: Bearer <token>
# or X-Import-Token: <token>
IMPORT_API_TOKEN=

DATABASE_URL=sqlite+aiosqlite:///./storage_leads.db
